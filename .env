# ═══════════════════════════════════════════════
# NovelSwarm Configuration
# ═══════════════════════════════════════════════

# LLM (Ollama local — runs on your GPU)
# Change LLM_BASE_URL if using a remote Ollama or OpenAI-compatible API
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=qwen2.5:7b
LLM_BOOST_MODEL=qwen2.5:7b

# Embedding model (Ollama — for vector DB semantic search)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# Neo4j Graph Database
# Set NEO4J_OPTIONAL=true to run without Neo4j (uses disk fallback)
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Waxct009@
NEO4J_OPTIONAL=true

# ChromaDB (runs embedded, no separate server needed)
CHROMA_PERSIST_DIR=./chroma_data

# Application
FLASK_PORT=5001
FLASK_DEBUG=false
UPLOAD_DIR=uploads

# Simulation
DEFAULT_AGENT_COUNT=1000
DEFAULT_ROUNDS=20
MAX_CONCURRENT_AGENTS=15
MAX_ACTIVE_AGENTS_PER_ROUND=30

# Limits (safety)
MAX_AGENT_COUNT=5000
MAX_ROUNDS=500
MAX_LORE_LENGTH=100000
